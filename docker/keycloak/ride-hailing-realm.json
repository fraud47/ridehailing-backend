{
  "realm": "ride-hailing",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "RIDER",
        "description": "Rider-facing API consumer"
      },
      {
        "name": "DRIVER",
        "description": "Driver-facing API consumer"
      },
      {
        "name": "DISPATCHER",
        "description": "Operations and dispatch staff"
      },
      {
        "name": "ADMIN",
        "description": "Platform administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "ride-hailing-api",
      "name": "Ride Hailing Ride Service",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:3000"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "rider.demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Rider",
      "lastName": "Demo",
      "email": "rider.demo@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "RIDER"
      ]
    },
    {
      "username": "driver.demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Driver",
      "lastName": "Demo",
      "email": "driver.demo@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "DRIVER"
      ]
    },
    {
      "username": "dispatcher.demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dispatch",
      "lastName": "Demo",
      "email": "dispatcher.demo@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
